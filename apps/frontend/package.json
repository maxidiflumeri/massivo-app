{
  "name": "@massivo/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:massivo": "vite --mode massivo",
    "dev:rgbot": "vite --mode rgbot",
    "build": "tsc -b && vite build",
    "build:massivo": "tsc -b && vite build --mode massivo",
    "build:rgbot": "tsc -b && vite build --mode rgbot",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.3",
    "@clerk/localizations": "^4.5.7",
    "@clerk/themes": "^2.4.57",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.0",
    "@mui/material": "^7.1.0",
    "@xyflow/react": "^12.10.2",
    "dagre": "^0.8.5",
    "jsonata": "^2.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-email-editor": "^1.8.0",
    "react-router-dom": "^7.6.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.3.0",
    "vitest": "^2.1.8"
  }
}
