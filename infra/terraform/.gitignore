# Terraform local state — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plugin cache + working dir
.terraform/
.terraform.tfstate.lock.info

# Variable files — may contain secrets
*.tfvars
!*.tfvars.example
*.auto.tfvars
*.auto.tfvars.json

# Crash logs
crash.log
crash.*.log

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
