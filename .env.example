# ===========================
# Massivo App - .env.example
# ===========================

# --- Node ---
NODE_ENV=development

# --- Backend ---
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:5173

# --- Database (Postgres) ---
DATABASE_URL=postgresql://massivo:massivo@localhost:5432/massivo?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Auth (Clerk) - Fase 1 ---
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- AWS / SES - Fase 3 ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_CONFIG_SET_PREFIX=massivo-team-
SES_SNS_WEBHOOK_SECRET=
# ARN del SNS topic al que SES publica BOUNCE/COMPLAINT/DELIVERY/OPEN/CLICK.
# Si está vacío, ensureConfigurationSet no configura event destination (modo dev).
SES_EVENTS_SNS_TOPIC_ARN=

# --- Email queue / worker (Fase 3.A) ---
EMAIL_QUEUE_NAME=email-send
EMAIL_WORKER_CONCURRENCY=5
EMAIL_WORKER_ENABLED=true
# Default sender driver cuando SmtpAccount.provider="smtp" (alternativa: "ses").
# En dev local: Mailpit en 127.0.0.1:1025 (instalación nativa en WSL, ver README).

# --- Email tracking (Fase 3.B) ---
EMAIL_TRACKING_JWT_SECRET=change-me-tracking-secret
EMAIL_PUBLIC_URL=http://localhost:3001

# --- Meta WhatsApp Business API - Fase 4 ---
META_GRAPH_API_VERSION=v20.0
# Override de la URL base del Graph API (sólo para staging / mocks). Si vacío,
# usa https://graph.facebook.com.
WAPI_GRAPH_BASE_URL=
# Worker BullMQ (4.A).
WAPI_QUEUE_NAME=wapi-send
WAPI_WORKER_CONCURRENCY=1
WAPI_WORKER_ENABLED=true
WAPI_DELAY_MIN_MS=30000
WAPI_DELAY_MAX_MS=60000
# Media (4.F.2.d): cache local de archivos enviados/recibidos por WhatsApp.
# Path absoluto o relativo al cwd del backend (apps/backend). Crece sin límite —
# definir política de retención más adelante.
WAPI_MEDIA_DIR=./uploads/wapi-media

# --- Dev Simulator (Fase 4.L) ---
# Si "true", expone POST /api/dev/wapi/simulate/{inbound|status} para inyectar
# webhooks Meta-shaped sin necesidad de Meta ni ngrok. Útil sólo en dev/staging.
# Con flag off, los endpoints devuelven 404. Si lo habilitás en backend, también
# habilitá VITE_ENABLE_DEV_SIMULATOR=true en el frontend para que aparezca el
# item "Simulador WhatsApp" en el sidebar y se monte la ruta.
ENABLE_DEV_SIMULATOR=false
VITE_ENABLE_DEV_SIMULATOR=false

# --- Bot guiado WhatsApp (Fase 4.O.1) ---
# Kill-switch global del feature de bots. Si "false", todos los endpoints del bot
# devuelven 403, el motor no intercepta inbounds y la UI oculta el item "Bots"
# del sidebar. La org también necesita Organization.botEnabled=true para acceder
# (cobramos como add-on de plan superior). Default false en prod por seguridad.
WAPI_BOT_FEATURE_ENABLED=false
# Frontend espejo del kill-switch global (oculta el item "Bot guiado" del
# sidebar y la ruta /dashboard/wapi/bots). El gating per-org se enforce desde
# backend (403). Ambas deben estar true para que la UI exponga el feature.
VITE_WAPI_BOT_FEATURE_ENABLED=false

# --- Encriptación at-rest (Fase 4.B) ---
# AES-256-GCM master key. 32 bytes en hex (64 chars) ó base64 (44 chars).
# Generar con: openssl rand -hex 32
# Si está vacía, los secretos se persisten en plaintext (modo legacy de dev).
# CRÍTICO: no perder la clave — sin ella, los WapiConfig encriptados son irrecuperables.
MASSIVO_ENCRYPTION_KEY=
MASSIVO_ENCRYPTION_KEY_B64=

# --- Billing - Fase 5 ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# --- AI (Gemini) - Fase 6 ---
GEMINI_API_KEY=

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Logging ---
LOG_LEVEL=debug

# --- JWT (firmas internas: tracking pixels, unsubscribe links) ---
INTERNAL_JWT_SECRET=change-me-in-production

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:3001
VITE_CLERK_PUBLISHABLE_KEY=
