# ===========================
# Massivo App - .env.example
# ===========================

# --- Node ---
NODE_ENV=development

# --- Backend ---
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:5173

# --- Database (Postgres) ---
DATABASE_URL=postgresql://massivo:massivo@localhost:5432/massivo?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Auth (Clerk) - Fase 1 ---
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- AWS / SES - Fase 3 ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_CONFIG_SET_PREFIX=massivo-team-
SES_SNS_WEBHOOK_SECRET=
# ARN del SNS topic al que SES publica BOUNCE/COMPLAINT/DELIVERY/OPEN/CLICK.
# Si está vacío, ensureConfigurationSet no configura event destination (modo dev).
SES_EVENTS_SNS_TOPIC_ARN=

# --- Email queue / worker (Fase 3.A) ---
EMAIL_QUEUE_NAME=email-send
EMAIL_WORKER_CONCURRENCY=5
EMAIL_WORKER_ENABLED=true
# Default sender driver cuando SmtpAccount.provider="smtp" (alternativa: "ses").
# En dev local: Mailpit en 127.0.0.1:1025 (instalación nativa en WSL, ver README).

# --- Email tracking (Fase 3.B) ---
EMAIL_TRACKING_JWT_SECRET=change-me-tracking-secret
EMAIL_PUBLIC_URL=http://localhost:3001

# --- Meta WhatsApp Business API - Fase 4 ---
META_GRAPH_API_VERSION=v20.0

# --- Billing - Fase 5 ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# --- AI (Gemini) - Fase 6 ---
GEMINI_API_KEY=

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Logging ---
LOG_LEVEL=debug

# --- JWT (firmas internas: tracking pixels, unsubscribe links) ---
INTERNAL_JWT_SECRET=change-me-in-production

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:3001
VITE_CLERK_PUBLISHABLE_KEY=
