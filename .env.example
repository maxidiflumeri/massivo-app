# ===========================
# Massivo App - .env.example
# ===========================

# --- Node ---
NODE_ENV=development

# --- Backend ---
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:5173
# Nombre/marca de la app (white-label). Default "Massivo". Cambialo por deploy (ej. APP_NAME=rgbot).
# Afecta el footer de los emails, el email de test SMTP y el prefijo del logger.
APP_NAME=Massivo

# --- Database (Postgres) ---
DATABASE_URL=postgresql://massivo:massivo@localhost:5432/massivo?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Auth (Clerk) - Fase 1 ---
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- AWS / SES - Fase 3 ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_CONFIG_SET_PREFIX=massivo-team-
SES_SNS_WEBHOOK_SECRET=
# ARN del SNS topic al que SES publica BOUNCE/COMPLAINT/DELIVERY/OPEN/CLICK.
# Si está vacío, ensureConfigurationSet no configura event destination (modo dev).
SES_EVENTS_SNS_TOPIC_ARN=

# --- Email queue / worker (Fase 3.A) ---
EMAIL_QUEUE_NAME=email-send
EMAIL_WORKER_CONCURRENCY=5
EMAIL_WORKER_ENABLED=true
# Default sender driver cuando SmtpAccount.provider="smtp" (alternativa: "ses").
# En dev local: Mailpit en 127.0.0.1:1025 (instalación nativa en WSL, ver README).

# --- Email tracking (Fase 3.B) ---
EMAIL_TRACKING_JWT_SECRET=change-me-tracking-secret
EMAIL_PUBLIC_URL=http://localhost:3001

# --- Meta WhatsApp Business API - Fase 4 ---
META_GRAPH_API_VERSION=v20.0
# Override de la URL base del Graph API (sólo para staging / mocks). Si vacío,
# usa https://graph.facebook.com.
WAPI_GRAPH_BASE_URL=
# Worker BullMQ (4.A).
WAPI_QUEUE_NAME=wapi-send
WAPI_WORKER_CONCURRENCY=1
WAPI_WORKER_ENABLED=true
WAPI_DELAY_MIN_MS=30000
WAPI_DELAY_MAX_MS=60000
# Media (4.F.2.d): cache local de archivos enviados/recibidos por WhatsApp.
# Path absoluto o relativo al cwd del backend (apps/backend). Crece sin límite —
# definir política de retención más adelante.
WAPI_MEDIA_DIR=./uploads/wapi-media

# --- Dev Simulator (Fase 4.L) ---
# Si "true", expone POST /api/dev/wapi/simulate/{inbound|status} para inyectar
# webhooks Meta-shaped sin necesidad de Meta ni ngrok. Útil sólo en dev/staging.
# Con flag off, los endpoints devuelven 404. Si lo habilitás en backend, también
# habilitá VITE_ENABLE_DEV_SIMULATOR=true en el frontend para que aparezca el
# item "Simulador WhatsApp" en el sidebar y se monte la ruta.
ENABLE_DEV_SIMULATOR=false
VITE_ENABLE_DEV_SIMULATOR=false

# --- Bot guiado WhatsApp (Fase 4.O.1) ---
# Kill-switch global de EMERGENCIA del motor de bots. El acceso de producto lo
# gobierna el plan de cada org (Plan.features.bot + limits.bots); esta variable
# solo existe para apagar TODO el motor sin deploy si algo se descontrola
# (loop con Meta, gasto de LLM desbocado). Si "false": endpoints 403, el motor
# ignora inbounds y la UI oculta "Bots" (features.bot del /me ya la incluye).
WAPI_BOT_FEATURE_ENABLED=false

# --- Encriptación at-rest (Fase 4.B) ---
# AES-256-GCM master key. 32 bytes en hex (64 chars) ó base64 (44 chars).
# Generar con: openssl rand -hex 32
# Si está vacía, los secretos se persisten en plaintext (modo legacy de dev).
# CRÍTICO: no perder la clave — sin ella, los WapiConfig encriptados son irrecuperables.
MASSIVO_ENCRYPTION_KEY=
MASSIVO_ENCRYPTION_KEY_B64=

# --- Billing - Fase 5 ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# --- AI (Gemini) - Fase 6 ---
GEMINI_API_KEY=

# --- Agentes IA / RAG (embeddings) ---
# Proveedor de embeddings para la base de conocimiento de los agentes.
# Soportado hoy: "voyage" (default). La dimensión del vector debe matchear la
# columna AgentChunk.embedding vector(1024); cambiar de proveedor con otra
# dimensión requiere migración + re-embeber los documentos.
EMBEDDING_PROVIDER=voyage
# API key de Voyage AI (https://dash.voyageai.com). voyage-3.5-lite, free tier
# de 200M tokens; requerida si EMBEDDING_PROVIDER=voyage y se usa la KB.
VOYAGE_API_KEY=

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Logging ---
LOG_LEVEL=debug

# --- JWT (firmas internas: tracking pixels, unsubscribe links) ---
INTERNAL_JWT_SECRET=change-me-in-production

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:3001
VITE_CLERK_PUBLISHABLE_KEY=
# Marca/dominios del frontend (white-label). Por deploy viven en .env.<target>
# (.env.massivo / .env.rgbot) y se eligen con `vite build --mode <target>`.
VITE_APP_NAME=Massivo
VITE_APP_TAGLINE=Multichannel sender
VITE_DOCS_URL=https://docs.massivo.app

# --- POC Bot Multas GBA (seed-bot-infracciones.ts) ---
# Token reCaptcha generado en infraccionesba.gba.gob.ar (rotar cuando se queme).
INFRACCIONES_RECAPTCHA_TOKEN=
# JSESSIONID cookie del server gba.gob.ar.
INFRACCIONES_JSESSIONID=
# Si seteás esto, el seed ATTACHEA el flow a la WapiConfig con ese phoneNumberId
# (típicamente tu config real con WhatsApp validado). Si lo dejás vacío, crea/
# upsertea una config POC con phoneNumberId=DEV_INFRACCIONES_SIM y isTestMode=true.
BOT_INFRACCIONES_PHONE_ID=

# --- Tunnel para webhook Meta (scripts/dev-tunnel.sh) ---
# Dominio estático reservado en https://dashboard.ngrok.com/domains (1 gratis
# en el free tier). Lo usa `pnpm dev:public` para exponer el backend al webhook
# de Meta sin URL random tras cada restart.
NGROK_DOMAIN=
