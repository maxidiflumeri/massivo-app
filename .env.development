# Defaults de marca para `vite` SIN --mode (dev plano). Con --mode massivo|rgbot
# Vite carga .env.<mode> y este archivo NO aplica. Solo lo que usa index.html
# (los %VITE_*%); el resto de la marca ya tiene defaults en código (brand.ts).
VITE_APP_NAME=Massivo
VITE_DOMAIN_ROOT=massivo.app
VITE_BRAND_PRIMARY="#5B5BD6"
VITE_BRAND_FAVICON=/favicon.svg
