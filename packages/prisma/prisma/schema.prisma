generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  CANCELED
}

enum OrgRole {
  OWNER
  ADMIN
  BILLING
  MEMBER
}

enum TeamRole {
  ADMIN
  MEMBER
  VIEWER
}

enum BillingProvider {
  STRIPE
  MERCADOPAGO
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum UsageMetric {
  EMAILS_SENT
  WAPI_MESSAGES_SENT
  CONTACTS
  AI_TOKENS
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  PAUSED
  COMPLETED
  FAILED
}

enum EmailReportStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
  COMPLAINED
}

enum EmailEventType {
  OPEN
  CLICK
}

enum EmailUnsubscribeScope {
  GLOBAL
  CAMPAIGN
}

enum ChannelKind {
  EMAIL
  WAPI
}

enum ScheduledTaskKind {
  EMAIL_DAILY_REPORT
  CAMPAIGN_DISPATCH
  CUSTOM
}

enum TaskExecutionStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  RETRYING
}

enum CampaignLogLevel {
  INFO
  WARN
  ERROR
}

model Organization {
  id               String    @id @default(cuid())
  clerkOrgId       String    @unique
  name             String
  slug             String    @unique
  planId           String
  plan             Plan      @relation(fields: [planId], references: [id])
  stripeCustomerId String?   @unique
  status           OrgStatus @default(ACTIVE)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  teams         Team[]
  memberships   OrgMembership[]
  subscriptions Subscription[]
  usageCounters UsageCounter[]
  auditLogs     AuditLog[]

  smtpAccounts      SmtpAccount[]
  emailTemplates    EmailTemplate[]
  emailCampaigns    EmailCampaign[]
  emailContacts     EmailContact[]
  emailReports      EmailReport[]
  emailEvents       EmailEvent[]
  emailBounces      EmailBounce[]
  emailUnsubscribes EmailUnsubscribe[]
  wapiConfigs       WapiConfig[]
  wapiTemplates     WapiTemplate[]
  wapiCampaigns     WapiCampaign[]
  wapiContacts      WapiContact[]
  wapiReports       WapiReport[]
  wapiConversations WapiConversation[]
  wapiMessages      WapiMessage[]
  wapiOptOuts       WapiOptOut[]

  contacts       Contact[]
  tags           Tag[]
  contactLists   ContactList[]
  scheduledTasks ScheduledTask[]
  taskExecutions TaskExecution[]
  campaignLogs   CampaignLog[]

  @@index([status])
}

model Team {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  isDefault      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  memberships TeamMembership[]

  smtpAccounts      SmtpAccount[]
  emailTemplates    EmailTemplate[]
  emailCampaigns    EmailCampaign[]
  emailContacts     EmailContact[]
  emailReports      EmailReport[]
  emailEvents       EmailEvent[]
  emailBounces      EmailBounce[]
  emailUnsubscribes EmailUnsubscribe[]
  wapiConfigs       WapiConfig[]
  wapiTemplates     WapiTemplate[]
  wapiCampaigns     WapiCampaign[]
  wapiContacts      WapiContact[]
  wapiReports       WapiReport[]
  wapiConversations WapiConversation[]
  wapiMessages      WapiMessage[]
  wapiOptOuts       WapiOptOut[]

  contacts       Contact[]
  tags           Tag[]
  contactLists   ContactList[]
  scheduledTasks ScheduledTask[]
  taskExecutions TaskExecution[]
  campaignLogs   CampaignLog[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String   @unique
  name        String?
  avatarUrl   String?
  createdAt   DateTime @default(now())

  orgMemberships  OrgMembership[]
  teamMemberships TeamMembership[]
}

model OrgMembership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model TeamMembership {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      TeamRole
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model Plan {
  id              String  @id @default(cuid())
  code            String  @unique
  name            String
  priceMonthlyUsd Decimal
  features        Json
  limits          Json
  isPublic        Boolean @default(true)

  organizations Organization[]
  subscriptions Subscription[]
}

model Subscription {
  id                 String          @id @default(cuid())
  organizationId     String
  planId             String
  provider           BillingProvider
  externalId         String
  status             SubStatus
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean         @default(false)

  organization Organization @relation(fields: [organizationId], references: [id])
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([organizationId])
}

model UsageCounter {
  id             String      @id @default(cuid())
  organizationId String
  metric         UsageMetric
  periodStart    DateTime
  periodEnd      DateTime
  value          BigInt      @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, metric, periodStart])
  @@index([organizationId, metric])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String?
  actorUserId    String?
  action         String
  resourceType   String?
  resourceId     String?
  metadata       Json?
  ip             String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, action])
}

// ============================================================
// Email channel (Fase 2 — sub-A)
// ============================================================

model SmtpAccount {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  name           String
  host           String
  port           Int
  username       String
  passwordEnc    String
  fromName       String
  fromEmail      String
  isActive       Boolean  @default(true)
  // "smtp" (default) usa host/port/username/passwordEnc (Mailpit en dev, SMTP de cliente).
  // "ses" usa AWS SES con configuration set sesConfigSet.
  provider       String   @default("smtp")
  sesConfigSet   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team           Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  emailTemplates EmailTemplate[]
  emailCampaigns EmailCampaign[]

  @@index([organizationId])
  @@index([teamId])
}

model EmailTemplate {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  name           String
  subject        String
  html           String
  design         Json
  smtpAccountId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  smtpAccount  SmtpAccount?    @relation(fields: [smtpAccountId], references: [id], onDelete: SetNull)
  campaigns    EmailCampaign[]

  @@index([organizationId])
  @@index([teamId])
}

model EmailCampaign {
  id              String              @id @default(cuid())
  organizationId  String
  teamId          String
  name            String
  status          EmailCampaignStatus @default(DRAFT)
  paused          Boolean             @default(false)
  archived        Boolean             @default(false)
  jobId           String?
  templateId      String?
  smtpAccountId   String?
  scheduledAt     DateTime?
  sentAt          DateTime?
  config          Json?
  createdByUserId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  template     EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  smtpAccount  SmtpAccount?   @relation(fields: [smtpAccountId], references: [id], onDelete: SetNull)
  contacts     EmailContact[]
  reports      EmailReport[]

  @@index([organizationId])
  @@index([teamId])
  @@index([teamId, status])
}

model EmailContact {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  campaignId     String
  email          String
  name           String?
  data           Json?
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaign     EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reports      EmailReport[]

  @@index([organizationId])
  @@index([teamId])
  @@index([campaignId])
}

model EmailReport {
  id             String            @id @default(cuid())
  organizationId String
  teamId         String
  campaignId     String
  contactId      String
  status         EmailReportStatus @default(PENDING)
  sentAt         DateTime?
  error          String?
  subject        String?
  html           String?
  trackingToken  String?           @unique
  smtpMessageId  String?           @unique
  firstOpenedAt  DateTime?
  firstClickedAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaign     EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact      EmailContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  events       EmailEvent[]
  bounces      EmailBounce[]

  @@index([organizationId])
  @@index([teamId])
  @@index([campaignId])
  @@index([teamId, status])
  @@index([sentAt])
}

model EmailEvent {
  id             String         @id @default(cuid())
  organizationId String
  teamId         String
  reportId       String
  type           EmailEventType
  targetUrl      String?
  targetDomain   String?
  occurredAt     DateTime       @default(now())
  ip             String?
  userAgent      String?
  deviceFamily   String?
  osName         String?
  osVersion      String?
  browserName    String?
  browserVersion String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  report       EmailReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([teamId])
  @@index([reportId, type, occurredAt])
  @@index([type, occurredAt])
}

model EmailBounce {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  reportId       String?
  occurredAt     DateTime @default(now())
  code           String?
  description    String?
  raw            String?
  email          String?
  smtpMessageId  String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  report       EmailReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([teamId])
  @@index([reportId, occurredAt])
}

model EmailUnsubscribe {
  id             String                @id @default(cuid())
  organizationId String
  teamId         String
  email          String
  emailHash      String
  scope          EmailUnsubscribeScope @default(GLOBAL)
  campaignId     String?
  reason         String?
  source         String?
  createdAt      DateTime              @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, emailHash, scope, campaignId])
  @@index([organizationId])
  @@index([teamId, emailHash])
}

// ============================================================
// WhatsApp channel (Fase 2 — sub-B)
// ============================================================

enum WapiCampaignStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  PAUSED
  COMPLETED
  FAILED
}

enum WapiReportStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum WapiConversationStatus {
  UNASSIGNED
  ASSIGNED
  RESOLVED
}

enum WapiOptOutScope {
  GLOBAL
  CAMPAIGN
}

model WapiConfig {
  id                    String   @id @default(cuid())
  organizationId        String
  teamId                String
  name                  String?
  phoneNumberId         String
  businessAccountId     String
  accessTokenEnc        String
  webhookVerifyTokenEnc String
  appSecretEnc          String?
  welcomeMessage        String?
  optOutConfirmMessage  String?
  dailyLimit            Int      @default(200)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team          Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaigns     WapiCampaign[]
  conversations WapiConversation[]

  @@unique([teamId, phoneNumberId])
  @@index([organizationId])
  @@index([teamId])
}

model WapiTemplate {
  id                String   @id @default(cuid())
  organizationId    String
  teamId            String
  metaName          String
  businessAccountId String   @default("")
  category          String
  language          String
  status            String
  components        Json
  buttonActions     Json?
  syncedAt          DateTime
  createdAt         DateTime @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaigns    WapiCampaign[]

  @@unique([teamId, metaName, businessAccountId])
  @@index([organizationId])
  @@index([teamId])
}

model WapiCampaign {
  id              String             @id @default(cuid())
  organizationId  String
  teamId          String
  name            String
  status          WapiCampaignStatus @default(DRAFT)
  paused          Boolean            @default(false)
  archived        Boolean            @default(false)
  jobId           String?
  templateId      String?
  configId        String?
  scheduledAt     DateTime?
  sentAt          DateTime?
  config          Json?
  createdByUserId String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  template     WapiTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  configRel    WapiConfig?   @relation(fields: [configId], references: [id], onDelete: SetNull)
  contacts     WapiContact[]
  reports      WapiReport[]

  @@index([organizationId])
  @@index([teamId])
  @@index([teamId, status])
}

model WapiContact {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  campaignId     String
  phone          String
  name           String?
  data           Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaign     WapiCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  report       WapiReport?

  @@index([organizationId])
  @@index([teamId])
  @@index([campaignId])
}

model WapiReport {
  id             String           @id @default(cuid())
  organizationId String
  teamId         String
  campaignId     String
  contactId      String           @unique
  phone          String
  metaMessageId  String?          @unique
  status         WapiReportStatus @default(PENDING)
  error          String?
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  failedAt       DateTime?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaign     WapiCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact      WapiContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([teamId])
  @@index([campaignId])
  @@index([teamId, status])
  @@index([sentAt])
}

model WapiConversation {
  id             String                 @id @default(cuid())
  organizationId String
  teamId         String
  configId       String
  phone          String
  name           String?
  status         WapiConversationStatus @default(UNASSIGNED)
  assignedUserId String?
  lastMessageAt  DateTime?
  window24hAt    DateTime?
  firstReplyAt   DateTime?
  resolvedAt     DateTime?
  unreadCount    Int                    @default(0)
  lastReadAt     DateTime?
  campaignName   String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  config       WapiConfig    @relation(fields: [configId], references: [id], onDelete: Cascade)
  messages     WapiMessage[]

  @@unique([teamId, configId, phone])
  @@index([organizationId])
  @@index([teamId])
  @@index([assignedUserId])
  @@index([status])
}

model WapiMessage {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  conversationId String
  metaMessageId  String?  @unique
  fromMe         Boolean
  type           String
  content        Json
  status         String   @default("sent")
  timestamp      DateTime
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  conversation WapiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([teamId])
  @@index([conversationId, timestamp])
}

model WapiOptOut {
  id             String          @id @default(cuid())
  organizationId String
  teamId         String
  phone          String
  phoneHash      String
  scope          WapiOptOutScope @default(GLOBAL)
  campaignId     String?
  reason         String?
  source         String?
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, phoneHash, scope, campaignId])
  @@index([organizationId])
  @@index([teamId, phoneHash])
}

// ============================================================
// Cross-cutting (Fase 2 — sub-C): Contact, Tag, ContactList,
// ScheduledTask, TaskExecution, CampaignLog
// ============================================================

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  email          String?
  phone          String?
  firstName      String?
  lastName       String?
  attributes     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tags         ContactTag[]
  listMembers  ContactListMember[]

  // Postgres permite múltiples NULL en columnas con UNIQUE: dos contacts del mismo team
  // sin email no chocan, pero dos con el mismo email sí. Lo mismo para phone.
  @@unique([teamId, email])
  @@unique([teamId, phone])
  @@index([organizationId])
  @@index([teamId])
}

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  name           String
  color          String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  contacts     ContactTag[]

  @@unique([teamId, name])
  @@index([organizationId])
  @@index([teamId])
}

model ContactTag {
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
}

model ContactList {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members      ContactListMember[]

  @@unique([teamId, name])
  @@index([organizationId])
  @@index([teamId])
}

model ContactListMember {
  listId    String
  contactId String
  addedAt   DateTime @default(now())

  list    ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([listId, contactId])
  @@index([contactId])
}

model ScheduledTask {
  id              String            @id @default(cuid())
  organizationId  String
  teamId          String
  name            String
  kind            ScheduledTaskKind
  enabled         Boolean           @default(true)
  cronExpression  String
  timezone        String            @default("America/Argentina/Buenos_Aires")
  config          Json
  recipients      Json?
  maxRetries      Int               @default(3)
  backoffMs       Int               @default(60000)
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  createdByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  executions   TaskExecution[]

  @@index([organizationId])
  @@index([teamId])
  @@index([nextRunAt])
}

model TaskExecution {
  id             String              @id @default(cuid())
  organizationId String
  teamId         String
  taskId         String
  startedAt      DateTime
  finishedAt     DateTime?
  status         TaskExecutionStatus
  error          String?
  artifacts      Json?
  logs           Json?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  task         ScheduledTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([teamId])
  @@index([taskId])
  @@index([startedAt])
}

model CampaignLog {
  id             String           @id @default(cuid())
  organizationId String
  teamId         String
  channel        ChannelKind
  campaignId     String
  level          CampaignLogLevel @default(INFO)
  message        String
  metadata       Json?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([teamId])
  @@index([channel, campaignId, createdAt])
}
