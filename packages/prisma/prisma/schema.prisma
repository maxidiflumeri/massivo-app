generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  CANCELED
}

enum OrgRole {
  OWNER
  ADMIN
  BILLING
  MEMBER
}

enum TeamRole {
  ADMIN
  MEMBER
  VIEWER
}

enum BillingProvider {
  STRIPE
  MERCADOPAGO
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum UsageMetric {
  EMAILS_SENT
  WAPI_MESSAGES_SENT
  CONTACTS
  AI_TOKENS
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  PAUSED
  COMPLETED
  FAILED
}

enum EmailReportStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
  COMPLAINED
  SUPPRESSED
  CANCELED
}

enum EmailEventType {
  OPEN
  CLICK
}

enum EmailUnsubscribeScope {
  GLOBAL
  CAMPAIGN
}

enum ChannelKind {
  EMAIL
  WAPI
}

enum ScheduledTaskKind {
  EMAIL_DAILY_REPORT
  CAMPAIGN_DISPATCH
  CUSTOM
}

enum TaskExecutionStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  RETRYING
}

enum CampaignLogLevel {
  INFO
  WARN
  ERROR
}

model Organization {
  id               String    @id @default(cuid())
  clerkOrgId       String    @unique
  name             String
  slug             String    @unique
  planId           String
  plan             Plan      @relation(fields: [planId], references: [id])
  stripeCustomerId String?   @unique
  status           OrgStatus @default(ACTIVE)
  // Feature flag por organización (4.O.1). Combinado con WAPI_BOT_FEATURE_ENABLED
  // (env kill-switch) gobierna acceso al motor de bots, endpoints CRUD y UI.
  // Default false: cobramos como add-on de plan superior, se enciende manual.
  botEnabled       Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  teams         Team[]
  memberships   OrgMembership[]
  subscriptions Subscription[]
  usageCounters UsageCounter[]
  auditLogs     AuditLog[]

  smtpAccounts      SmtpAccount[]
  emailTemplates    EmailTemplate[]
  emailCampaigns    EmailCampaign[]
  emailContacts     EmailContact[]
  emailReports      EmailReport[]
  emailEvents       EmailEvent[]
  emailBounces      EmailBounce[]
  emailUnsubscribes EmailUnsubscribe[]
  wapiConfigs         WapiConfig[]
  wapiTemplates       WapiTemplate[]
  wapiCampaigns       WapiCampaign[]
  wapiContacts        WapiContact[]
  wapiReports         WapiReport[]
  wapiConversations   WapiConversation[]
  wapiMessages        WapiMessage[]
  wapiOptOuts         WapiOptOut[]
  wapiQuickReplies    WapiQuickReply[]
  wapiResolutionNotes WapiResolutionNote[]
  wapiBotSessions     WapiBotSession[]

  contacts       Contact[]
  tags           Tag[]
  contactLists   ContactList[]
  scheduledTasks ScheduledTask[]
  taskExecutions TaskExecution[]
  campaignLogs   CampaignLog[]

  @@index([status])
}

model Team {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  isDefault      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  memberships TeamMembership[]

  smtpAccounts      SmtpAccount[]
  emailTemplates    EmailTemplate[]
  emailCampaigns    EmailCampaign[]
  emailContacts     EmailContact[]
  emailReports      EmailReport[]
  emailEvents       EmailEvent[]
  emailBounces      EmailBounce[]
  emailUnsubscribes EmailUnsubscribe[]
  wapiConfigs         WapiConfig[]
  wapiTemplates       WapiTemplate[]
  wapiCampaigns       WapiCampaign[]
  wapiContacts        WapiContact[]
  wapiReports         WapiReport[]
  wapiConversations   WapiConversation[]
  wapiMessages        WapiMessage[]
  wapiOptOuts         WapiOptOut[]
  wapiQuickReplies    WapiQuickReply[]
  wapiResolutionNotes WapiResolutionNote[]
  wapiBotSessions     WapiBotSession[]

  contacts       Contact[]
  tags           Tag[]
  contactLists   ContactList[]
  scheduledTasks ScheduledTask[]
  taskExecutions TaskExecution[]
  campaignLogs   CampaignLog[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String   @unique
  name        String?
  avatarUrl   String?
  createdAt   DateTime @default(now())

  orgMemberships  OrgMembership[]
  teamMemberships TeamMembership[]
}

model OrgMembership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model TeamMembership {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      TeamRole
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model Plan {
  id              String  @id @default(cuid())
  code            String  @unique
  name            String
  priceMonthlyUsd Decimal
  features        Json
  limits          Json
  isPublic        Boolean @default(true)

  organizations Organization[]
  subscriptions Subscription[]
}

model Subscription {
  id                 String          @id @default(cuid())
  organizationId     String
  planId             String
  provider           BillingProvider
  externalId         String
  status             SubStatus
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean         @default(false)

  organization Organization @relation(fields: [organizationId], references: [id])
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([organizationId])
}

model UsageCounter {
  id             String      @id @default(cuid())
  organizationId String
  metric         UsageMetric
  periodStart    DateTime
  periodEnd      DateTime
  value          BigInt      @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, metric, periodStart])
  @@index([organizationId, metric])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String?
  actorUserId    String?
  action         String
  resourceType   String?
  resourceId     String?
  metadata       Json?
  ip             String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, action])
}

// ============================================================
// Email channel (Fase 2 — sub-A)
// ============================================================

model SmtpAccount {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  name           String
  host           String
  port           Int
  username       String
  passwordEnc    String
  fromName       String
  fromEmail      String
  isActive       Boolean  @default(true)
  // "smtp" (default) usa host/port/username/passwordEnc (Mailpit en dev, SMTP de cliente).
  // "ses" usa AWS SES con configuration set sesConfigSet.
  provider       String   @default("smtp")
  sesConfigSet   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team           Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  emailTemplates EmailTemplate[]
  emailCampaigns EmailCampaign[]

  @@index([organizationId])
  @@index([teamId])
}

model EmailTemplate {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  name           String
  subject        String
  html           String
  design         Json
  smtpAccountId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  smtpAccount  SmtpAccount?    @relation(fields: [smtpAccountId], references: [id], onDelete: SetNull)
  campaigns    EmailCampaign[]

  @@index([organizationId])
  @@index([teamId])
}

model EmailCampaign {
  id              String              @id @default(cuid())
  organizationId  String
  teamId          String
  name            String
  status          EmailCampaignStatus @default(DRAFT)
  paused          Boolean             @default(false)
  archived        Boolean             @default(false)
  jobId           String?
  templateId      String?
  smtpAccountId   String?
  scheduledAt     DateTime?
  sentAt          DateTime?
  config          Json?
  createdByUserId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  template     EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  smtpAccount  SmtpAccount?   @relation(fields: [smtpAccountId], references: [id], onDelete: SetNull)
  contacts     EmailContact[]
  reports      EmailReport[]

  @@index([organizationId])
  @@index([teamId])
  @@index([teamId, status])
}

model EmailContact {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  campaignId     String
  email          String
  name           String?
  data           Json?
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaign     EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reports      EmailReport[]

  @@index([organizationId])
  @@index([teamId])
  @@index([campaignId])
}

model EmailReport {
  id             String            @id @default(cuid())
  organizationId String
  teamId         String
  campaignId     String
  contactId      String
  status         EmailReportStatus @default(PENDING)
  sentAt         DateTime?
  error          String?
  subject        String?
  html           String?
  trackingToken  String?           @unique
  smtpMessageId  String?           @unique
  firstOpenedAt  DateTime?
  firstClickedAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaign     EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact      EmailContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  events       EmailEvent[]
  bounces      EmailBounce[]

  @@index([organizationId])
  @@index([teamId])
  @@index([campaignId])
  @@index([teamId, status])
  @@index([sentAt])
}

model EmailEvent {
  id             String         @id @default(cuid())
  organizationId String
  teamId         String
  reportId       String
  type           EmailEventType
  targetUrl      String?
  targetDomain   String?
  occurredAt     DateTime       @default(now())
  ip             String?
  userAgent      String?
  deviceFamily   String?
  osName         String?
  osVersion      String?
  browserName    String?
  browserVersion String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  report       EmailReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([teamId])
  @@index([reportId, type, occurredAt])
  @@index([type, occurredAt])
}

model EmailBounce {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  reportId       String?
  occurredAt     DateTime @default(now())
  code           String?
  description    String?
  raw            String?
  email          String?
  smtpMessageId  String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  report       EmailReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([teamId])
  @@index([reportId, occurredAt])
}

model EmailUnsubscribe {
  id             String                @id @default(cuid())
  organizationId String
  teamId         String
  email          String
  emailHash      String
  scope          EmailUnsubscribeScope @default(GLOBAL)
  campaignId     String?
  reason         String?
  source         String?
  createdAt      DateTime              @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, emailHash, scope, campaignId])
  @@index([organizationId])
  @@index([teamId, emailHash])
}

// ============================================================
// WhatsApp channel (Fase 2 — sub-B)
// ============================================================

enum WapiCampaignStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  PAUSED
  COMPLETED
  FAILED
}

enum WapiReportStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  CANCELED
}

enum WapiConversationStatus {
  UNASSIGNED
  ASSIGNED
  RESOLVED
}

enum WapiOptOutScope {
  GLOBAL
  CAMPAIGN
}

model WapiConfig {
  id                    String   @id @default(cuid())
  organizationId        String
  teamId                String
  name                  String?
  phoneNumberId         String
  businessAccountId     String
  accessTokenEnc        String
  webhookVerifyTokenEnc String
  appSecretEnc          String?
  welcomeMessage        String?
  optOutConfirmMessage  String?
  // Keywords case-insensitive que disparan opt-out automático al recibirse
  // como texto inbound. Si vacío, se usan los defaults internos del webhook
  // handler (BAJA, STOP, UNSUBSCRIBE, CANCELAR).
  optOutKeywords        String[] @default([])
  dailyLimit            Int      @default(200)
  isActive              Boolean  @default(true)
  // Si true, el sender NO pega a Meta — devuelve un wamid SIM_ y persiste el
  // mensaje como si Meta hubiera respondido OK. Usado por la página
  // /dashboard/dev/wapi/chat para simular ida-vuelta completo sin tocar Meta.
  isTestMode            Boolean  @default(false)
  // Bot guiado por número (4.M). Si botEnabled=true y botFlow no es null, el
  // webhook intercepta los inbounds y los pasa por el motor de bot antes que
  // welcome/opt-out/4.K. botFlow es un JSON con shape:
  //   { startNodeId: string, nodes: { [id]: { kind: 'MENU'|'HANDOFF', text: string,
  //     options?: [{ id, label, nextNodeId }] } } }
  // sessionTtlMin define después de cuántos minutos sin interacción la sesión
  // del bot expira (cliente vuelve a empezar en startNodeId al próximo inbound).
  botEnabled            Boolean  @default(false)
  botFlow               Json?
  botSessionTtlMin      Int      @default(30)
  // 4.O.1 — sistema multi-tema. botTopics: Array<{id,label,flow:BotFlow}>.
  // botRouter: { rules: BotRouterRule[], defaultTopicId?: string } decide a qué
  // tema entrar según template-payload (regex named groups) o keyword exacto.
  // Si ambos (botFlow legacy + botTopics) están seteados, el motor prefiere
  // topics; botFlow se mantiene para backward compat (se materializa como
  // tema 'default' al vuelo si topics está vacío).
  botTopics             Json?
  botRouter             Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team          Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaigns     WapiCampaign[]
  conversations WapiConversation[]
  botSessions   WapiBotSession[]

  @@unique([teamId, phoneNumberId])
  @@index([organizationId])
  @@index([teamId])
}

model WapiTemplate {
  id                String   @id @default(cuid())
  organizationId    String
  teamId            String
  metaName          String
  businessAccountId String   @default("")
  category          String
  language          String
  status            String
  components        Json
  buttonActions     Json?
  syncedAt          DateTime
  createdAt         DateTime @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaigns    WapiCampaign[]

  @@unique([teamId, metaName, businessAccountId])
  @@index([organizationId])
  @@index([teamId])
}

model WapiCampaign {
  id              String             @id @default(cuid())
  organizationId  String
  teamId          String
  name            String
  status          WapiCampaignStatus @default(DRAFT)
  paused          Boolean            @default(false)
  archived        Boolean            @default(false)
  jobId           String?
  templateId      String?
  configId        String?
  scheduledAt     DateTime?
  sentAt          DateTime?
  config          Json?
  createdByUserId String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  template     WapiTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  configRel    WapiConfig?   @relation(fields: [configId], references: [id], onDelete: SetNull)
  contacts     WapiContact[]
  reports      WapiReport[]

  @@index([organizationId])
  @@index([teamId])
  @@index([teamId, status])
}

model WapiContact {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  campaignId     String
  phone          String
  name           String?
  data           Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaign     WapiCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  report       WapiReport?

  @@index([organizationId])
  @@index([teamId])
  @@index([campaignId])
}

model WapiReport {
  id             String           @id @default(cuid())
  organizationId String
  teamId         String
  campaignId     String
  contactId      String           @unique
  phone          String
  metaMessageId  String?          @unique
  status         WapiReportStatus @default(PENDING)
  error          String?
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  failedAt       DateTime?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaign     WapiCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact      WapiContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([teamId])
  @@index([campaignId])
  @@index([teamId, status])
  @@index([sentAt])
}

model WapiConversation {
  id             String                 @id @default(cuid())
  organizationId String
  teamId         String
  configId       String
  phone          String
  name           String?
  status         WapiConversationStatus @default(UNASSIGNED)
  assignedUserId String?
  lastMessageAt  DateTime?
  window24hAt    DateTime?
  firstReplyAt   DateTime?
  resolvedAt     DateTime?
  unreadCount    Int                    @default(0)
  lastReadAt     DateTime?
  campaignName   String?
  // Marcada como prioridad alta — se setea cuando el cliente apreta el botón
  // INBOX en un template interactivo (4.K). El inbox tiene un filtro y un
  // badge ⭐ para destacarlas.
  priority       Boolean                @default(false)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team            Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  config          WapiConfig           @relation(fields: [configId], references: [id], onDelete: Cascade)
  messages        WapiMessage[]
  resolutionNotes WapiResolutionNote[]

  @@unique([teamId, configId, phone])
  @@index([organizationId])
  @@index([teamId])
  @@index([assignedUserId])
  @@index([status])
  @@index([teamId, status, lastMessageAt])
  @@index([teamId, priority, lastMessageAt])
}

model WapiMessage {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  conversationId String
  metaMessageId  String?  @unique
  fromMe         Boolean
  type           String
  content        Json
  status         String   @default("sent")
  timestamp      DateTime
  createdAt      DateTime @default(now())

  // Media (4.F.2.d). NULL para mensajes de texto puros.
  // mediaLocalPath = path relativo al WAPI_MEDIA_DIR (no exponer al cliente).
  mediaId        String?
  mediaMime      String?
  mediaSha256    String?
  mediaSize      Int?
  mediaFilename  String?
  mediaCaption   String?
  mediaLocalPath String?

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  conversation WapiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([teamId])
  @@index([conversationId, timestamp])
  @@index([teamId, mediaSha256])
}

model WapiOptOut {
  id             String          @id @default(cuid())
  organizationId String
  teamId         String
  phone          String
  phoneHash      String
  scope          WapiOptOutScope @default(GLOBAL)
  campaignId     String?
  reason         String?
  source         String?
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, phoneHash, scope, campaignId])
  @@index([organizationId])
  @@index([teamId, phoneHash])
}

model WapiQuickReply {
  id              String   @id @default(cuid())
  organizationId  String
  teamId          String
  shortcut        String
  body            String
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, shortcut])
  @@index([organizationId])
  @@index([teamId])
}

model WapiResolutionNote {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  conversationId String
  authorUserId   String?
  note           String
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  conversation WapiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([teamId])
  @@index([conversationId, createdAt])
}

// Sesión de bot guiado (4.M). Una sesión activa = el cliente está navegando el
// flow del bot. Cuando llega un inbound, el motor busca por (configId, phone) y
// si existe + no expiró, decide el próximo nodo según la opción seleccionada.
// Sesión finaliza cuando se llega a un nodo HANDOFF o el operador toma manual.
model WapiBotSession {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  configId       String
  phone          String
  currentNodeId  String
  // 4.O.1 — id del tema (BotTopic) en el que está parado el cliente. Null para
  // sesiones legacy (botFlow sin topics) — el motor las trata como tema 'default'.
  currentTopicId String?
  startedAt      DateTime @default(now())
  lastInboundAt  DateTime @default(now())
  expiresAt      DateTime
  endedAt        DateTime?
  endedReason    String?
  // Variables capturadas por nodos CAPTURE (4.N.2). Forma libre Json,
  // claves = nombres definidos en saveAs. Se usa para interpolación {{var}}
  // en MESSAGE/CAPTURE/MEDIA y para ramas CONDITION{kind:'var'}.
  data           Json?    @default("{}")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  config       WapiConfig   @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, phone])
  @@index([organizationId])
  @@index([teamId])
  @@index([expiresAt])
}

// ============================================================
// Cross-cutting (Fase 2 — sub-C): Contact, Tag, ContactList,
// ScheduledTask, TaskExecution, CampaignLog
// ============================================================

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  email          String?
  phone          String?
  firstName      String?
  lastName       String?
  attributes     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tags         ContactTag[]
  listMembers  ContactListMember[]

  // Postgres permite múltiples NULL en columnas con UNIQUE: dos contacts del mismo team
  // sin email no chocan, pero dos con el mismo email sí. Lo mismo para phone.
  @@unique([teamId, email])
  @@unique([teamId, phone])
  @@index([organizationId])
  @@index([teamId])
}

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  name           String
  color          String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  contacts     ContactTag[]

  @@unique([teamId, name])
  @@index([organizationId])
  @@index([teamId])
}

model ContactTag {
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
}

model ContactList {
  id             String   @id @default(cuid())
  organizationId String
  teamId         String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members      ContactListMember[]

  @@unique([teamId, name])
  @@index([organizationId])
  @@index([teamId])
}

model ContactListMember {
  listId    String
  contactId String
  addedAt   DateTime @default(now())

  list    ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([listId, contactId])
  @@index([contactId])
}

model ScheduledTask {
  id              String            @id @default(cuid())
  organizationId  String
  teamId          String
  name            String
  kind            ScheduledTaskKind
  enabled         Boolean           @default(true)
  cronExpression  String
  timezone        String            @default("America/Argentina/Buenos_Aires")
  config          Json
  recipients      Json?
  maxRetries      Int               @default(3)
  backoffMs       Int               @default(60000)
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  createdByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  executions   TaskExecution[]

  @@index([organizationId])
  @@index([teamId])
  @@index([nextRunAt])
}

model TaskExecution {
  id             String              @id @default(cuid())
  organizationId String
  teamId         String
  taskId         String
  startedAt      DateTime
  finishedAt     DateTime?
  status         TaskExecutionStatus
  error          String?
  artifacts      Json?
  logs           Json?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  task         ScheduledTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([teamId])
  @@index([taskId])
  @@index([startedAt])
}

model CampaignLog {
  id             String           @id @default(cuid())
  organizationId String
  teamId         String
  channel        ChannelKind
  campaignId     String
  level          CampaignLogLevel @default(INFO)
  message        String
  metadata       Json?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([teamId])
  @@index([channel, campaignId, createdAt])
}
